{
  "geode": "5.0.3",
  "gd": "2.2081",
  "version": "1.7.0",
  "id": "tpdea.betterpause-better",
  "name": "BetterPause",
  "developer": "Tpdea",
  "description": "A mod inspired by the collar server, an improvement for the geometry dash pause menu.",
  "repository": "https://github.com",
  "issues": {
    "info": "Report any issues you have on GitHub issues.",
    "url": "https://github.com/issues"
  },
  "platforms": {
    "android": {
      "build": "arm64-v8a"
    }
  },
  "early-load": true,
  "settings": {
    "type-pause": {
      "name": "Select Pause",
      "description": "Choose the type of pause style you want: \n1. BetterPause \n2. ClassicPause \n3. SimplePause \n0. DisablePause.",
      "type": "int",
      "default": 1,
      "min": 0,
      "max": 3,
      "control": {
        "arrows": true,
        "slider": true
      }
    },
    "level-editor-hack": {
      "name": "Level Editor Hack",
      "description": "Compatibility for level editor menus.",
      "type": "bool",
      "default": false
    },
    "show-comment-button": {
      "name": "Show Comment button",
      "type": "bool",
      "default": false
    },
    "disable-arrow-blink": {
      "name": "Disable Arrow Blink",
      "type": "bool",
      "default": false
    },
    "amount-scroll-button": {
      "name": "Scroll Amount Button",
      "type": "float",
      "default": 20.0,
      "min": 1.0,
      "control": {
        "arrows": true,
        "slider": false
      }
    },
    "disable-arrow-buttons": {
      "name": "Disable Arrow Buttons",
      "type": "bool",
      "default": false
    },
    "disable-creator-label": {
      "name": "Disable Level Author and Rating Label",
      "type": "bool",
      "default": false
    },
    "tolerance-in-buttons-list": {
      "name": "Tolerance in Buttons List",
      "type": "float",
      "default": 1.0,
      "min": 0,
      "max": 2,
      "control": {
        "arrows": true,
        "slider": true
      }
    },
    "enabled-info-button": {
      "name": "Enabled Info Button",
      "type": "bool",
      "default": false
    },
    "enabled-coins-viewer": {
      "name": "Enabled Coins Viewer",
      "type": "bool",
      "default": false
    },
    "original-comment-button-sprite": {
      "name": "Original Comment Button Sprite",
      "type": "bool",
      "default": false
    },
    "remove-exit-hotkey": {
      "name": "Remove Exit Hotkey",
      "type": "bool",
      "default": false
    },
    "confirm-resume-level": {
      "name": "Confirm Resume Level",
      "type": "bool",
      "default": false
    },
    "confirm-restart-level": {
      "name": "Confirm Restart Level",
      "type": "bool",
      "default": false
    }
  },
  "resources": {
    "sprites": [
      "resources/*.png"
    ]
  },
  "tags": [
    "Customization",
    "Interface",
    "Enhancement"
  ],
  "dependencies": [
    {
      "id": "geode.node-ids",
      "version": ">=v1.22.0",
      "importance": "required"
    }
  ]
}

